# ══════════════════════════════════════════════════
#   OXE BALL — Environment Variables
#   Add these in Railway → your project → Variables
# ══════════════════════════════════════════════════

# Server (Railway sets PORT automatically — leave blank)
PORT=3000
APP_URL=https://your-app.up.railway.app

# Security — REQUIRED in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex

# Admin panel password — REQUIRED
ADMIN_PASSWORD=change_me_now

# Email — choose ONE option:

# Option A: Resend (recommended, free 3000/month — resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option B: Gmail SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_16char_app_password
# SMTP_FROM=OXE BALL <your@gmail.com>

# Google OAuth (optional — get from console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com

# Referral reward in OXE (default: 15)
REFERRAL_REWARD_OXE=15
